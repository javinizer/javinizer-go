# Example secrets file for act (local GitHub Actions testing)
# Copy this file to .secrets and fill in your actual values
# WARNING: Never commit .secrets to git (it's in .gitignore)

# Docker Hub credentials (for testing Docker builds)
DOCKERHUB_USERNAME=your-username
DOCKERHUB_TOKEN=your-token

# GitHub token (for testing release workflows)
GITHUB_TOKEN=your-github-token

# Usage:
# 1. Copy this file: cp .secrets.example .secrets
# 2. Edit .secrets with your actual values
# 3. Run act with: act --secret-file .secrets
# 4. Or configure in .actrc for automatic loading
